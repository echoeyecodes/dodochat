{
  "name": "groupchat",
  "private": true,
  "workspaces": [
    "website",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n \"web,srv\" -c \"cyan,magenta\" \"bun run --filter website dev\" \"bun run --filter server dev\"",
    "dev:web": "bun run --filter website dev",
    "dev:srv": "bun run --filter server dev",
    "build": "bun run --filter '*' build",
    "start": "concurrently -n \"web,srv\" -c \"cyan,magenta\" \"bun run --filter website serve\" \"bun run --filter server start\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "server/**/*.{ts,js}": [
      "bun run --filter server format:check",
      "bun run --filter server lint"
    ],
    "website/**/*.{ts,tsx,js,jsx}": [
      "bun run --filter website format:check",
      "bun run --filter website lint"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
